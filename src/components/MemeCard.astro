---
import TagPill from './TagPill.astro';

interface Props {
  id: string;
  title: string;
  description: string | null;
  filePath: string;
  fileUrl: string;
  fileType: string;
  tags: Array<{ id: string; name: string }>;
  sharedUrl?: string | null;
  giphyUrl?: string | null;
  activeTags?: string[];
}

const { id, title, description, fileUrl, fileType, tags, sharedUrl, giphyUrl, activeTags = [] } = Astro.props;
---

<article class="meme-card" data-meme-id={id} id={`meme-${id}`}>
  <div class="media-container">
    {fileType === 'video' ? (
      <video 
        src={fileUrl} 
        controls 
        playsinline 
        preload="metadata"
        class="media"
      >
        Your browser does not support video playback.
      </video>
    ) : (
      <img 
        src={fileUrl} 
        alt={title} 
        loading="lazy" 
        class="media"
        onerror="this.style.display='none'"
      />
    )}
  </div>

  <div class="content">
    <div class="header">
      <h2 class="title">{title}</h2>
      <div class="header-actions">
        <button 
          type="button" 
          class="edit-btn" 
          data-meme-id={id}
          data-meme-title={title}
          data-meme-description={description || ''}
          data-meme-file-url={fileUrl}
          data-meme-file-type={fileType}
          data-meme-tags={JSON.stringify(tags)}
          data-meme-shared-url={sharedUrl || ''}
          data-meme-giphy-url={giphyUrl || ''}
          aria-label="Edit meme tags"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
          </svg>
        </button>
        <button 
          type="button" 
          class="share-btn" 
          data-meme-id={id}
          aria-label="Share meme to ImgBB"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="share-icon">
            <circle cx="18" cy="5" r="3"></circle>
            <circle cx="6" cy="12" r="3"></circle>
            <circle cx="18" cy="19" r="3"></circle>
            <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line>
            <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line>
          </svg>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="loading-icon" style="display: none;">
            <circle cx="12" cy="12" r="10"></circle>
            <path d="M12 6v6l4 2"></path>
          </svg>
        </button>
        <button 
          type="button" 
          class="giphy-share-btn" 
          data-meme-id={id}
          aria-label="Share meme to Giphy"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" class="giphy-icon">
            <path d="M2 2h20v20H2V2zm2 2v16h16V4H4zm2 2h12v2H6V6zm0 4h12v2H6v-2zm0 4h8v2H6v-2z"/>
          </svg>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="loading-icon" style="display: none;">
            <circle cx="12" cy="12" r="10"></circle>
            <path d="M12 6v6l4 2"></path>
          </svg>
        </button>
        <button 
          type="button" 
          class="delete-btn" 
          data-meme-id={id}
          aria-label="Delete meme"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M3 6h18M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2m3 0v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6h14z"/>
            <line x1="10" y1="11" x2="10" y2="17"/>
            <line x1="14" y1="11" x2="14" y2="17"/>
          </svg>
        </button>
      </div>
    </div>

    {description && (
      <p class="description">{description}</p>
    )}

    {(sharedUrl || giphyUrl) && (
      <div class="cached-links">
        {sharedUrl && (
          <div class="cached-link">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="link-icon">
              <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
              <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
            </svg>
            <span class="link-label">ImgBB</span>
            <a href={sharedUrl} target="_blank" rel="noopener noreferrer" class="link-url">{sharedUrl.replace(/^https?:\/\//, '').slice(0, 25)}...</a>
            <button type="button" class="copy-link-btn" data-url={sharedUrl} aria-label="Copy ImgBB link">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
              </svg>
            </button>
          </div>
        )}
        {giphyUrl && (
          <div class="cached-link">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" class="link-icon giphy">
              <path d="M2 2h20v20H2V2zm2 2v16h16V4H4zm2 2h12v2H6V6zm0 4h12v2H6v-2zm0 4h8v2H6v-2z"/>
            </svg>
            <span class="link-label giphy">GIPHY</span>
            <a href={giphyUrl} target="_blank" rel="noopener noreferrer" class="link-url">{giphyUrl.replace(/^https?:\/\//, '').slice(0, 25)}...</a>
            <button type="button" class="copy-link-btn" data-url={giphyUrl} aria-label="Copy Giphy link">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
              </svg>
            </button>
          </div>
        )}
      </div>
    )}

    {tags.length > 0 && (
      <div class="tags">
        {tags.map((tag) => (
          <TagPill name={tag.name} active={activeTags.includes(tag.name)} />
        ))}
      </div>
    )}
  </div>
</article>

<script>
  import { navigate } from 'astro:transitions/client';

  // Save scroll position before navigation, restore after
  function navigatePreservingScroll() {
    sessionStorage.setItem('memenator-scroll', String(window.scrollY));
    navigate(window.location.pathname + window.location.search);
  }

  function initMemeCards() {
    // Edit button handlers
    document.querySelectorAll('.edit-btn').forEach((btn) => {
      if ((btn as any)._initialized) return;
      (btn as any)._initialized = true;

      btn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        
        const memeId = btn.getAttribute('data-meme-id');
        const title = btn.getAttribute('data-meme-title');
        const description = btn.getAttribute('data-meme-description');
        const fileUrl = btn.getAttribute('data-meme-file-url');
        const fileType = btn.getAttribute('data-meme-file-type');
        const tagsJson = btn.getAttribute('data-meme-tags');
        const sharedUrl = btn.getAttribute('data-meme-shared-url');
        const giphyUrl = btn.getAttribute('data-meme-giphy-url');
        
        if (!memeId || !title || !fileUrl || !fileType || !tagsJson) return;

        try {
          const tags = JSON.parse(tagsJson);
          (window as any).openEditMemeModal?.({
            id: memeId,
            title,
            description: description || null,
            fileUrl,
            fileType,
            tags,
            sharedUrl: sharedUrl || null,
            giphyUrl: giphyUrl || null,
          });
        } catch (err) {
          console.error('Failed to parse meme data:', err);
        }
      });
    });

    document.querySelectorAll('.delete-btn').forEach((btn) => {
      if ((btn as any)._initialized) return;
      (btn as any)._initialized = true;

      btn.addEventListener('click', async (e) => {
        e.preventDefault();
        e.stopPropagation();
        
        const memeId = btn.getAttribute('data-meme-id');
        if (!memeId) return;

        const confirmed = confirm('Are you sure you want to delete this meme?');
        if (!confirmed) return;

        try {
          const response = await fetch(`/api/memes/${memeId}`, {
            method: 'DELETE',
          });

          if (!response.ok) {
            throw new Error('Delete failed');
          }

          // Use navigate to refresh page with view transitions (updates sidebar too)
          navigate(window.location.pathname + window.location.search);
        } catch (error) {
          alert('Failed to delete meme');
        }
      });
    });

    document.querySelectorAll('.share-btn').forEach((btn) => {
      if ((btn as any)._initialized) return;
      (btn as any)._initialized = true;

      btn.addEventListener('click', async (e) => {
        e.preventDefault();
        e.stopPropagation();
        
        const memeId = btn.getAttribute('data-meme-id');
        if (!memeId) return;

        const shareIcon = btn.querySelector('.share-icon') as HTMLElement;
        const loadingIcon = btn.querySelector('.loading-icon') as HTMLElement;
        
        btn.setAttribute('disabled', 'true');
        if (shareIcon) shareIcon.style.display = 'none';
        if (loadingIcon) {
          loadingIcon.style.display = 'block';
          loadingIcon.classList.add('spinning');
        }

        try {
          const response = await fetch('/api/share', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ memeId }),
          });

          const result = await response.json();

          if (result.success && result.link) {
            (window as any).showToast?.({
              type: 'success',
              message: result.cached ? 'Copied ImgBB link!' : 'Shared to ImgBB!',
              link: result.link,
            });
            
            // Navigate preserving scroll to show cached link
            if (!result.cached) {
              setTimeout(() => navigatePreservingScroll(), 1000);
            }
          } else {
            (window as any).showToast?.({
              type: 'error',
              message: result.error || 'Failed to share',
            });
          }
        } catch (error) {
          (window as any).showToast?.({
            type: 'error',
            message: 'Failed to connect to share service',
          });
        } finally {
          btn.removeAttribute('disabled');
          if (shareIcon) shareIcon.style.display = 'block';
          if (loadingIcon) {
            loadingIcon.style.display = 'none';
            loadingIcon.classList.remove('spinning');
          }
        }
      });
    });

    document.querySelectorAll('.giphy-share-btn').forEach((btn) => {
      if ((btn as any)._initialized) return;
      (btn as any)._initialized = true;

      btn.addEventListener('click', async (e) => {
        e.preventDefault();
        e.stopPropagation();
        
        const memeId = btn.getAttribute('data-meme-id');
        if (!memeId) return;

        const giphyIcon = btn.querySelector('.giphy-icon') as HTMLElement;
        const loadingIcon = btn.querySelector('.loading-icon') as HTMLElement;
        
        btn.setAttribute('disabled', 'true');
        if (giphyIcon) giphyIcon.style.display = 'none';
        if (loadingIcon) {
          loadingIcon.style.display = 'block';
          loadingIcon.classList.add('spinning');
        }

        // Show uploading toast
        (window as any).showToast?.({
          type: 'info',
          message: 'Uploading to Giphy...',
        });

        try {
          const response = await fetch('/api/share/giphy', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ memeId }),
          });

          const result = await response.json();

          if (result.success && result.copyText) {
            // Copy to clipboard with tags
            try {
              await navigator.clipboard.writeText(result.copyText);
              
              (window as any).showToast?.({
                type: 'success',
                message: result.cached ? 'Copied Giphy link!' : 'Uploaded to Giphy & copied!',
                link: result.url,
              });
              
              // Navigate preserving scroll to show cached link
              if (!result.cached) {
                setTimeout(() => navigatePreservingScroll(), 1000);
              }
            } catch (clipboardError) {
              // Fallback if clipboard API fails
              (window as any).showToast?.({
                type: 'success',
                message: 'Uploaded to Giphy!',
                link: result.url,
              });
              
              if (!result.cached) {
                setTimeout(() => navigatePreservingScroll(), 1000);
              }
            }
          } else {
            (window as any).showToast?.({
              type: 'error',
              message: result.error || 'Failed to share to Giphy',
            });
          }
        } catch (error) {
          (window as any).showToast?.({
            type: 'error',
            message: 'Failed to connect to Giphy service',
          });
        } finally {
          btn.removeAttribute('disabled');
          if (giphyIcon) giphyIcon.style.display = 'block';
          if (loadingIcon) {
            loadingIcon.style.display = 'none';
            loadingIcon.classList.remove('spinning');
          }
        }
      });
    });

    // Copy link buttons for cached URLs
    document.querySelectorAll('.copy-link-btn').forEach((btn) => {
      if ((btn as any)._initialized) return;
      (btn as any)._initialized = true;

      btn.addEventListener('click', async (e) => {
        e.preventDefault();
        e.stopPropagation();
        
        const url = btn.getAttribute('data-url');
        if (!url) return;

        try {
          await navigator.clipboard.writeText(url);
          (window as any).showToast?.({
            type: 'success',
            message: 'Link copied!',
          });
        } catch (error) {
          (window as any).showToast?.({
            type: 'error',
            message: 'Failed to copy link',
          });
        }
      });
    });

    const videos = document.querySelectorAll('video[preload="metadata"]');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const video = entry.target as HTMLVideoElement;
          video.preload = 'auto';
          observer.unobserve(video);
        }
      });
    }, { rootMargin: '100px' });

    videos.forEach((video) => observer.observe(video));
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMemeCards);
  } else {
    initMemeCards();
  }
  
  document.addEventListener('astro:page-load', initMemeCards);
</script>

<style>
  .meme-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: border-color 0.15s ease;
  }

  .meme-card:hover {
    border-color: var(--color-accent);
  }

  .media-container {
    background: var(--color-bg);
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 200px;
    position: relative;
  }

  .media {
    width: 100%;
    height: auto;
    max-height: 500px;
    object-fit: contain;
    display: block;
  }

  .content {
    padding: var(--spacing-lg);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  .header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--spacing-md);
  }

  .header-actions {
    display: flex;
    gap: var(--spacing-xs);
    flex-shrink: 0;
  }

  .title {
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1.3;
    margin: 0;
  }

  .edit-btn,
  .share-btn,
  .giphy-share-btn,
  .delete-btn {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-text-muted);
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .edit-btn:hover {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: white;
  }

  .share-btn:hover {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: white;
  }

  .share-btn:disabled {
    cursor: not-allowed;
    opacity: 0.7;
  }

  .giphy-share-btn:hover {
    background: #00ff99;
    border-color: #00ff99;
    color: #000;
  }

  .giphy-share-btn:disabled {
    cursor: not-allowed;
    opacity: 0.7;
  }

  .delete-btn:hover {
    background: var(--color-error);
    border-color: var(--color-error);
    color: white;
  }

  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  .spinning {
    animation: spin 1s linear infinite;
  }

  .description {
    color: var(--color-text-muted);
    font-size: 0.875rem;
    line-height: 1.5;
    margin: 0;
  }

  .cached-links {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
    margin-top: var(--spacing-xs);
  }

  .cached-link {
    display: flex;
    align-items: center;
    gap: var(--spacing-xs);
    padding: var(--spacing-xs) var(--spacing-sm);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-size: 0.75rem;
  }

  .cached-link .link-icon {
    flex-shrink: 0;
    color: var(--color-accent);
  }

  .cached-link .link-icon.giphy {
    color: #00ff99;
  }

  .cached-link .link-label {
    font-weight: 600;
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .cached-link .link-label.giphy {
    color: #00ff99;
  }

  .cached-link .link-url {
    color: var(--color-text-muted);
    text-decoration: none;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    flex: 1;
    min-width: 0;
  }

  .cached-link .link-url:hover {
    color: var(--color-text);
    text-decoration: underline;
  }

  .copy-link-btn {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    color: var(--color-text-muted);
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .copy-link-btn:hover {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: white;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-xs);
    margin-top: var(--spacing-xs);
  }
</style>
