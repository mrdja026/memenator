---
interface Props {
  src: string;
  type: 'image' | 'video';
  alt?: string;
}

const { src, type, alt = 'Media preview' } = Astro.props;
---

<div class="media-preview">
  {type === 'video' ? (
    <video src={src} controls playsinline class="media">
      Your browser does not support video playback.
    </video>
  ) : (
    <img src={src} alt={alt} loading="lazy" class="media" />
  )}
</div>

<style>
  .media-preview {
    width: 100%;
    background: var(--color-bg);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .media {
    width: 100%;
    height: auto;
    display: block;
    max-height: 400px;
    object-fit: contain;
  }
</style>
