# Astro DB Remote Connection
ASTRO_DB_REMOTE_URL=http://localhost:8080
ASTRO_DB_APP_TOKEN=

# Docker Compose Ports
LIBSQL_PORT=8080
APP_PORT=4321

# MinIO Object Storage
# For local-only: http://localhost:9000
# For network access from other devices: http://YOUR_IP:9000 (e.g., http://192.168.0.151:9000)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=memenator-media
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
